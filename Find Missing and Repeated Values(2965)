class Solution:
    def findMissingAndRepeatedValues(self, grid: List[List[int]]) -> List[int]:
        freq = {}
        n = len(grid)
        for row in grid:
            for element in row :
                if element in freq :
                    freq[element] += 1
                else :
                    freq[element] = 1
        for i in range(1, (n*n)+1) :
            if i in freq :
                if freq[i] == 2:
                    repeated = i
            else :
                missing = i
        return [repeated, missing]
