class Solution:
    def convert(self, s: str, numRows: int) -> str:
        
        if numRows == 1 or numRows >= len(s) :
            return s

        rows = [""]*numRows
        currrow = 0
        direction = -1
        for ch in s :
            rows[currrow] += ch

            if currrow == 0 or currrow == numRows-1 :
                direction *= -1
            currrow += direction

        return "".join(rows)
